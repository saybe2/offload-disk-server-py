# Пример конфигурации
# Скопируйте в .env и заполните значения

# Секретный ключ для сессий Flask (сгенерируйте случайную строку)
SECRET_KEY=your-secret-key-here

# Ключ шифрования файлов (32 символа для AES-256)
MASTER_KEY=your-32-character-master-key-here

# Discord Webhook URL для хранения файлов
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Опционально: путь к базе данных (по умолчанию sqlite:///data/storage.db)
# DATABASE_URL=sqlite:///data/storage.db

# Опционально: максимальный размер файла в МБ (по умолчанию 25)
# MAX_FILE_SIZE_MB=25

# Опционально: размер чанка в МБ (по умолчанию 8)
# CHUNK_SIZE_MB=8
